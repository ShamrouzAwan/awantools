# AWAN Tools Platform — Apache configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Routing ──────────────────────────────────────────────────────────────────
Options -Indexes
RewriteEngine On

# Block direct access to sensitive directories/files
RewriteRule ^(_core|_database|_lang|_bootstrap|_config|start\.sh|README) - [F,L]

# Block direct access to PHP files inside plugins/ (only index.php served via directory route)
RewriteRule ^plugins/[^/]+/.+\.php$ - [F,L]

# Block storage/ except uploads/
RewriteRule ^storage/(?!uploads/) - [F,L]

# Route all non-file requests through _router.php.
# index.php and all other PHP entry points require AWAN to be defined by the router,
# so they cannot be served directly by Apache — everything must go through _router.php.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ _router.php [QSA,L]

# ── Security Headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Default: block camera everywhere
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Allow camera only on the scannable-codes plugin (needed for QR/barcode scanner)
    <LocationMatch "^/plugins/scannable-codes(/.*)?$">
        Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=()"
    </LocationMatch>

    # CSP — set at Apache level so it overrides any host-injected CSP.
    # Dual CSP headers cause browsers to enforce the most restrictive intersection,
    # which blocks cdnjs.cloudflare.com fonts and breaks FontAwesome icons.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' cdn.jsdelivr.net cdn.quilljs.com cdn.tiny.cloud cdnjs.cloudflare.com chart.googleapis.com www.google.com www.gstatic.com www.googletagmanager.com www.clarity.ms pagead2.googlesyndication.com googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdn.quilljs.com cdn.tiny.cloud cdnjs.cloudflare.com; img-src 'self' data: blob: https:; font-src 'self' data: cdn.jsdelivr.net cdnjs.cloudflare.com; worker-src 'self' blob: data:; connect-src 'self' https: wss:; frame-src 'self' www.google.com www.googletagmanager.com; object-src 'none'; base-uri 'self';"
</IfModule>
