{
  "slug": "default",
  "name": "AWAN Default",
  "version": "1.0",
  "author": "AWAN Platform",
  "description": "Professional AWAN blue theme with light and dark mode support",
  "screenshot": "screenshot.png",

  "variables": {
    "color-background": "#f1f5f9",
    "color-surface": "#ffffff",
    "color-card": "#ffffff",

    "color-sidebar": "#061F52",
    "color-sidebar-surface": "#0B1E46",
    "color-sidebar-text": "#A8B6D3",
    "color-sidebar-text-active": "#ffffff",
    "color-sidebar-active-bg": "#10337D",

    "color-primary": "#0F6BFF",
    "color-primary-hover": "#0052E0",
    "color-primary-light": "#EAF3FF",

    "color-success": "#10b981",
    "color-success-light": "#d1fae5",

    "color-danger": "#ef4444",
    "color-danger-light": "#fee2e2",

    "color-warning": "#f59e0b",
    "color-warning-light": "#fef3c7",

    "color-info": "#0F6BFF",
    "color-info-light": "#EAF3FF",

    "color-text": "#0f172a",
